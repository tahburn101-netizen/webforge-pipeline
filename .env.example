# ============================================================
# WebForge Backend — environment template
# Copy this file to backend/.env and fill in your own keys
# ============================================================

# --- Database -----------------------------------------------
MONGO_URL="mongodb://localhost:27017"
DB_NAME="webforge_db"

# --- CORS ---------------------------------------------------
CORS_ORIGINS="*"

# --- Vercel (REQUIRED) --------------------------------------
# Get one at https://vercel.com/account/tokens
VERCEL_TOKEN=""

# --- LLM Provider -------------------------------------------
# OPTION A: Use Emergent Universal LLM Key (free for users on app.emergent.sh)
# Get yours at: https://app.emergent.sh -> Profile -> Universal Key
EMERGENT_LLM_KEY=""

# OPTION B: Use direct Google AI Studio key (works WITHOUT Emergent)
# Get one at https://aistudio.google.com/apikey
# Used for: Gemini 2.5 Pro (text + vision), Nano Banana (image gen)
# GOOGLE_API_KEY=""

# OPTIONAL alt providers (for future text-LLM fallbacks):
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""

# --- (server-only) GitHub token for self-hosted CI ----------
# Only needed if you wire up GitHub Actions or repo creation features.
# GITHUB_TOKEN=""
